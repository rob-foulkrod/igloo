@model web.Models.Event

@{
    ViewData["Title"] = "Event Details";
    var regCount = (int)ViewBag.RegistrationCount;
    var remaining = (int)ViewBag.RemainingCapacity;
    var pct = Model.Capacity > 0 ? (int)(regCount * 100.0 / Model.Capacity) : 0;
    var barClass = remaining == 0 ? "capacity-bar capacity-bar-full" : "capacity-bar";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header-frost">
                <h3 class="mb-0"><i class="bi bi-calendar-event"></i> @Model.Title</h3>
            </div>
            <div class="card-body">
                <p class="text-muted mb-4">@Model.Description</p>

                <div class="row mb-3">
                    <div class="col-sm-6">
                        <p class="mb-1"><i class="bi bi-calendar3 text-primary"></i> <strong>Start:</strong> @Model.StartDate.ToString("f")</p>
                        <p class="mb-1"><i class="bi bi-calendar3 text-primary"></i> <strong>End:</strong> @Model.EndDate.ToString("f")</p>
                    </div>
                    <div class="col-sm-6">
                        <p class="mb-1"><i class="bi bi-geo-alt-fill text-primary"></i> <strong>Location:</strong> @Model.Location</p>
                        <p class="mb-1"><i class="bi bi-people-fill text-primary"></i> <strong>Capacity:</strong> @Model.Capacity</p>
                    </div>
                </div>

                <div class="mb-3">
                    <div class="d-flex justify-content-between mb-1">
                        <small class="fw-bold">Registrations: @regCount / @Model.Capacity</small>
                        <small class="text-muted">@remaining spots remaining</small>
                    </div>
                    <div class="@barClass" style="height: 10px;">
                        <div class="progress-bar" role="progressbar" style="width: @(pct)%; height: 100%;"></div>
                    </div>
                </div>
            </div>
            <div class="card-footer bg-transparent">
                @if (remaining > 0)
                {
                    <a asp-controller="Registrations" asp-action="Create" asp-route-eventId="@Model.Id"
                       class="btn btn-primary me-2">
                        <i class="bi bi-person-plus"></i> Register
                    </a>
                }
                else
                {
                    <span class="btn btn-outline-danger disabled me-2">
                        <i class="bi bi-x-circle"></i> Event Full
                    </span>
                }
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-secondary me-2">
                    <i class="bi bi-pencil"></i> Edit
                </a>
                <a asp-action="Index" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left"></i> Back to List
                </a>
            </div>
        </div>
    </div>
</div>
