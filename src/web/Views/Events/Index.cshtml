@model IEnumerable<web.Models.Event>

@{
    ViewData["Title"] = "Events";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="mb-0"><i class="bi bi-calendar-event"></i> Events</h1>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg"></i> Create New Event
    </a>
</div>

<div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
    @foreach (var item in Model)
    {
        <div class="col">
            <div class="card event-card h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <h5 class="card-title mb-0">@item.Title</h5>
                        <span class="badge-date">
                            <i class="bi bi-calendar3"></i> @item.StartDate.ToString("MMM d")
                        </span>
                    </div>
                    <div class="event-meta mt-3">
                        <p class="mb-1"><i class="bi bi-geo-alt-fill"></i> @item.Location</p>
                        <p class="mb-2"><i class="bi bi-people-fill"></i> @item.Capacity spots</p>
                    </div>
                    <div class="capacity-bar mt-2">
                        <div class="progress-bar" role="progressbar" style="width: 0%"></div>
                    </div>
                </div>
                <div class="card-footer bg-transparent border-0 pt-0">
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-primary me-1">
                        <i class="bi bi-eye"></i> Details
                    </a>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary me-1">
                        <i class="bi bi-pencil"></i> Edit
                    </a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">
                        <i class="bi bi-trash"></i> Delete
                    </a>
                </div>
            </div>
        </div>
    }
</div>
